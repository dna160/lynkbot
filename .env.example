# ============================================================
# LynkBot Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://user:pass@localhost:5432/lynkbot?sslmode=disable
REDIS_URL=redis://localhost:6379

# --- API Server ---
PORT=3000
WORKER_CONCURRENCY=5
JWT_SECRET=replace_with_64_char_random_string
LYNK_INTERNAL_API_KEY=replace_with_internal_api_key

# --- xAI (Grok chat + Embeddings — NO OpenAI) ---
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
LLM_MODEL=grok-4-1-fast-reasoning
LLM_PROVIDER=xai
LLM_FALLBACK_MODEL=grok-3
XAI_EMBEDDING_MODEL=text-embedding-3-small

# --- WATI WhatsApp Gateway ---
WATI_BASE_URL=https://live-server.wati.io
WATI_API_KEY=
WATI_CHANNEL_NUMBER=
WATI_ALLOWED_IPS=
# Set to true only after WATI Partner agreement is signed
WATI_PARTNER_ENABLED=false

# --- Payments ---
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=
# midtrans or xendit
PAYMENT_PROVIDER=midtrans

# --- Shipping ---
RAJAONGKIR_API_KEY=
RAJAONGKIR_BASE_URL=https://pro.rajaongkir.com/api
GOOGLE_MAPS_API_KEY=

# --- File Storage (AWS S3 or Cloudflare R2) ---
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# For Cloudflare R2: https://accountid.r2.cloudflarestorage.com
S3_ENDPOINT=

# --- Observability ---
SENTRY_DSN=
LOG_LEVEL=info

# --- CORS ---
CORS_ORIGIN=http://localhost:5173
