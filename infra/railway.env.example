# LynkBot Railway environment variables
# Set these in Railway dashboard: Project → Service → Variables

DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Fill these from your .env.example
JWT_SECRET=
LYNK_INTERNAL_API_KEY=
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
LLM_MODEL=grok-4-1-fast-reasoning
LLM_PROVIDER=xai
LLM_FALLBACK_MODEL=grok-3
XAI_EMBEDDING_MODEL=text-embedding-3-small
WATI_BASE_URL=https://live-server.wati.io
WATI_API_KEY=
WATI_WEBHOOK_SECRET=
WATI_PARTNER_ENABLED=false
PAYMENT_PROVIDER=midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=true
RAJAONGKIR_API_KEY=
GOOGLE_MAPS_API_KEY=
S3_BUCKET=
S3_REGION=ap-southeast-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
SENTRY_DSN=
