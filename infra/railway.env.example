# ─── LynkBot Railway Environment Variables ─────────────────────────────────
# Set these in Railway → Project → each service → Variables tab.
# DATABASE_URL and REDIS_URL use Railway's variable interpolation syntax — they
# are auto-resolved to the Railway-managed Postgres and Redis plugins.

# ── Database + Cache ──────────────────────────────────────────────────────
DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}

# ── Runtime ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ── Security ──────────────────────────────────────────────────────────────
JWT_SECRET=                       # openssl rand -hex 32
LYNK_INTERNAL_API_KEY=            # openssl rand -hex 32

# ── AI (xAI / Grok) ──────────────────────────────────────────────────────
XAI_API_KEY=                      # from https://console.x.ai
XAI_BASE_URL=https://api.x.ai/v1
LLM_MODEL=grok-4-1-fast-reasoning
LLM_PROVIDER=xai
LLM_FALLBACK_MODEL=grok-3
XAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Meta WhatsApp Cloud API ───────────────────────────────────────────────
META_ACCESS_TOKEN=                # System User token from Meta Business Manager
META_PHONE_NUMBER_ID=536516392872816
META_WABA_ID=538059646048440
META_APP_SECRET=                  # Meta Developer Console → App Settings → Basic
META_WEBHOOK_VERIFY_TOKEN=lynkbot_webhook_verify
META_API_VERSION=v23.0

# ── Shipping ──────────────────────────────────────────────────────────────
RAJAONGKIR_API_KEY=               # Raja Ongkir Pro key
RAJAONGKIR_BASE_URL=https://pro.rajaongkir.com/api

# ── Payments ──────────────────────────────────────────────────────────────
PAYMENT_PROVIDER=midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=true
# XENDIT_SECRET_KEY=
# XENDIT_WEBHOOK_TOKEN=

# ── Storage (optional at MVP) ─────────────────────────────────────────────
S3_BUCKET=
S3_REGION=ap-southeast-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=                    # for non-AWS S3 (e.g. Cloudflare R2)

# ── Monitoring ────────────────────────────────────────────────────────────
# SENTRY_DSN=

# ─── Dashboard Build Variable ────────────────────────────────────────────
# Set this in Railway → lynkbot-dashboard → Variables → BUILD section (not Runtime):
#   VITE_API_URL = https://<lynkbot-api public domain>
# Find API public domain: Railway → lynkbot-api → Settings → Networking → Public Domain
#
# After deploy, update Meta webhook:
#   Meta Developer Console → App → WhatsApp → Configuration → Webhook URL:
#   https://<lynkbot-api public domain>/webhooks/meta
